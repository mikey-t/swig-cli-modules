{
  "name": "swig-cli-modules",
  "version": "0.3.5",
  "description": "Groups of swig tasks for use in other projects",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikey-t/swig-cli-modules.git"
  },
  "type": "module",
  "exports": {
    "./types": {
      "import": {
        "types": "./dist/esm/types/index.d.ts",
        "default": "./dist/esm/types/index.js"
      },
      "require": {
        "types": "./dist/cjs/types/index.d.ts",
        "default": "./dist/cjs/types/index.js"
      }
    },
    "./ConfigDockerCompose": {
      "import": {
        "types": "./dist/esm/config/singleton/DockerComposeConfigSingleton.d.ts",
        "default": "./dist/esm/config/singleton/DockerComposeConfigSingleton.js"
      },
      "require": {
        "types": "./dist/cjs/config/singleton/DockerComposeConfigSingleton.d.ts",
        "default": "./dist/cjs/config/singleton/DockerComposeConfigSingleton.js"
      }
    },
    "./ConfigDotnetReactSandbox": {
      "import": {
        "types": "./dist/esm/config/singleton/DotnetReactSandboxConfigSingleton.d.ts",
        "default": "./dist/esm/config/singleton/DotnetReactSandboxConfigSingleton.js"
      },
      "require": {
        "types": "./dist/cjs/config/singleton/DotnetReactSandboxConfigSingleton.d.ts",
        "default": "./dist/cjs/config/singleton/DotnetReactSandboxConfigSingleton.js"
      }
    },
    "./ConfigEntityFramework": {
      "import": {
        "types": "./dist/esm/config/singleton/EntityFrameworkConfigSingleton.d.ts",
        "default": "./dist/esm/config/singleton/EntityFrameworkConfigSingleton.js"
      },
      "require": {
        "types": "./dist/cjs/config/singleton/EntityFrameworkConfigSingleton.d.ts",
        "default": "./dist/cjs/config/singleton/EntityFrameworkConfigSingleton.js"
      }
    },
    "./DockerCompose": {
      "import": {
        "types": "./dist/esm/modules/DockerCompose/DockerCompose.d.ts",
        "default": "./dist/esm/modules/DockerCompose/DockerCompose.js"
      },
      "require": {
        "types": "./dist/cjs/modules/DockerCompose/DockerCompose.d.ts",
        "default": "./dist/cjs/modules/DockerCompose/DockerCompose.js"
      }
    },
    "./DotnetReactSandbox": {
      "import": {
        "types": "./dist/esm/modules/DotnetReactSandbox/DotnetReactSandbox.d.ts",
        "default": "./dist/esm/modules/DotnetReactSandbox/DotnetReactSandbox.js"
      },
      "require": {
        "types": "./dist/cjs/modules/DotnetReactSandbox/DotnetReactSandbox.d.ts",
        "default": "./dist/cjs/modules/DotnetReactSandbox/DotnetReactSandbox.js"
      }
    },
    "./EntityFramework": {
      "import": {
        "types": "./dist/esm/modules/EntityFramework/EntityFramework.d.ts",
        "default": "./dist/esm/modules/EntityFramework/EntityFramework.js"
      },
      "require": {
        "types": "./dist/cjs/modules/EntityFramework/EntityFramework.d.ts",
        "default": "./dist/cjs/modules/EntityFramework/EntityFramework.js"
      }
    },
    "./EntityFrameworkUtils": {
      "import": {
        "types": "./dist/esm/modules/EntityFramework/EntityFrameworkUtils.d.ts",
        "default": "./dist/esm/modules/EntityFramework/EntityFrameworkUtils.js"
      },
      "require": {
        "types": "./dist/cjs/modules/EntityFramework/EntityFrameworkUtils.d.ts",
        "default": "./dist/cjs/modules/EntityFramework/EntityFrameworkUtils.js"
      }
    },
    "./utils": {
      "import": {
        "types": "./dist/esm/utils/index.d.ts",
        "default": "./dist/esm/utils/index.js"
      },
      "require": {
        "types": "./dist/cjs/utils/index.d.ts",
        "default": "./dist/cjs/utils/index.js"
      }
    }
  },
  "scripts": {},
  "files": [
    "dist/",
    "readme.md",
    "LICENSE"
  ],
  "keywords": [
    "swig",
    "swig-cli",
    "swig-cli-modules",
    "dotnet-react-sandbox",
    "docker-compose",
    "entity-framework",
    "database-migrations",
    "docker",
    "docker-compose",
    "automation",
    "dev-workflow"
  ],
  "author": "Mike Thompson",
  "license": "MIT",
  "dependencies": {
    "@mikeyt23/node-cli-utils": "^2.1.1",
    "swig-cli": "^1.0.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "c8": "^11.0.0",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.14.0"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "^10.33.0",
      "onFail": "ignore"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
